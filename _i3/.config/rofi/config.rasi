//----------------------
// Configuration
//----------------------

configuration {
	modi: 			"drun,run";
	width: 			550;
	lines: 			13;
	font: 			"Monospace 16";
	show-match: 		false;
	separator-style: 	"solid";
	hide-scrollbar: 	true;
	theme:			"~/.config/rofi/rofi-themes/themes-yusoli/nord.rasi";
	}
