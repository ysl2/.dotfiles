" ===============
" === general ===
" ===============

let mapleader=' '
syntax on
set number
set relativenumber
set splitright
set splitbelow
set hlsearch
exec "nohlsearch"
set expandtab
set tabstop=4



" ==============
" === keymap ===
" ==============

noremap <leader>M :w<CR>:source ~/.vimrc<CR>
noremap <leader>m :tabe ~/.vimrc<CR>

